<div class="container" style="padding:40px 0">
  <div class="section-header">
    <h1>Shop</h1>
    <p><%= BRAND.tagline %></p>
  </div>

  <% if (collections && collections.length > 0) { %>
  <div class="collection-filters">
    <a href="/products" class="<%= !activeCollection ? 'active' : '' %>">All</a>
    <% collections.forEach(c => { %>
    <a href="/products?collection=<%= c.id %>" class="<%= activeCollection === c.id ? 'active' : '' %>">
      <%= c.name %>
    </a>
    <% }) %>
  </div>
  <% } %>

  <% if (error) { %>
  <div class="alert"><%= error %></div>
  <% } %>

  <% if (products && products.length > 0) { %>
  <div class="grid">
    <% products.forEach(p => { %>
    <a href="/products/<%= p.id %>" style="color:inherit;text-decoration:none">
      <div class="card">
        <img src="<%= p.image || p.images?.[0] || '' %>" alt="<%= p.title %>">
        <div class="card-body">
          <div class="collection-tag"><%= p.collection === 'nova-signature' ? 'Nova Signature' : 'The Basics' %></div>
          <h3><%= p.title %></h3>
          <div class="price">$<%= typeof p.price === 'number' ? p.price.toFixed(2) : parseFloat(p.variants?.[0]?.price || p.price).toFixed(2) %></div>
        </div>
      </div>
    </a>
    <% }) %>
  </div>
  <% } else { %>
  <p class="text-center" style="color:#888;padding:60px 0">No products found. Check back soon.</p>
  <% } %>
</div>
