<div class="container">
  <h1>All Products</h1>
  <p style="color:#999;margin-bottom:24px">Synced from Printify · <%= products.length %> items</p>
  <% if (error) { %><div class="alert"><%= error %></div><% } %>
  <div class="grid">
    <% products.forEach(p => { %>
    <a href="/products/<%= p.id %>" style="text-decoration:none;color:inherit">
      <div class="card">
        <img src="<%= p.images[0] || 'https://placehold.co/400x400/1a3a2a/fff?text=Nova' %>" alt="<%= p.title %>">
        <div class="card-body">
          <h3><%= p.title %></h3>
          <div class="price">$<%= p.variants[0]?.price || '29.99' %></div>
        </div>
      </div>
    </a>
    <% }) %>
  </div>
</div>
