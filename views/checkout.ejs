<div class="container">
  <h1>Checkout</h1>
  <% if (typeof error !== 'undefined' && error) { %><div class="alert"><%= error %></div><% } %>
  <div style="display:grid;grid-template-columns:1fr 400px;gap:40px;align-items:start">
    <form action="/checkout" method="POST" class="checkout-form">
      <h3 style="margin-bottom:16px">Shipping Information</h3>
      <div class="row">
        <input name="firstName" placeholder="First Name" required>
        <input name="lastName" placeholder="Last Name" required>
      </div>
      <input name="email" type="email" placeholder="Email" required>
      <input name="phone" placeholder="Phone (optional)">
      <input name="address" placeholder="Address" required>
      <input name="address2" placeholder="Apt, Suite, etc. (optional)">
      <div class="row">
        <input name="city" placeholder="City" required>
        <select name="state" required>
          <option value="">State</option>
          <option value="NY">New York</option><option value="CA">California</option><option value="TX">Texas</option>
          <option value="FL">Florida</option><option value="IL">Illinois</option><option value="PA">Pennsylvania</option>
          <option value="NJ">New Jersey</option><option value="GA">Georgia</option><option value="NC">North Carolina</option>
          <option value="VA">Virginia</option><option value="MA">Massachusetts</option><option value="WA">Washington</option>
        </select>
      </div>
      <div class="row">
        <input name="zip" placeholder="ZIP Code" required>
        <select name="country">
          <option value="US">United States</option>
        </select>
      </div>
      <button type="submit" class="btn" style="width:100%;margin-top:12px">
        Pay $<%= total %> — Continue to Stripe
      </button>
    </form>
    <div style="background:#fff;padding:20px;border-radius:8px">
      <h3 style="margin-bottom:16px">Order Summary</h3>
      <% cart.forEach(item => { %>
      <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:14px">
        <span><%= item.title %> × <%= item.quantity %></span>
        <span>$<%= (parseFloat(item.price) * item.quantity).toFixed(2) %></span>
      </div>
      <% }) %>
      <hr style="margin:12px 0">
      <div style="display:flex;justify-content:space-between;font-weight:700;font-size:18px">
        <span>Total</span><span>$<%= total %></span>
      </div>
    </div>
  </div>
</div>
