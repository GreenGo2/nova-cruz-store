<div class="container cart-page">
  <h1>Your Cart</h1>

  <% if (!cart || cart.length === 0) { %>
  <div class="cart-empty">
    <h2>Your cart is empty</h2>
    <p>Time to change that. Your next workout deserves fresh gear.</p>
    <a href="/products" class="btn">Shop Now</a>
  </div>
  <% } else { %>

  <table class="cart-table">
    <thead>
      <tr>
        <th>Product</th>
        <th>Price</th>
        <th>Quantity</th>
        <th>Total</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% cart.forEach((item, index) => { %>
      <tr>
        <td>
          <div class="cart-item">
            <img src="<%= item.image || '' %>" alt="<%= item.title %>" onerror="this.style.display='none'">
            <div class="cart-item-info">
              <h4><%= item.title %></h4>
              <% if (item.color) { %><span>Color: <%= item.color %></span><% } %>
              <% if (item.size) { %><span>Size: <%= item.size %></span><% } %>
            </div>
          </div>
        </td>
        <td>$<%= parseFloat(item.price).toFixed(2) %></td>
        <td>
          <form method="POST" action="/cart/update" class="qty-form">
            <input type="hidden" name="index" value="<%= index %>">
            <input type="number" name="quantity" value="<%= item.quantity %>" min="1" max="10">
            <button type="submit">Update</button>
          </form>
        </td>
        <td>$<%= (parseFloat(item.price) * item.quantity).toFixed(2) %></td>
        <td>
          <form method="POST" action="/cart/remove/<%= index %>" style="display:inline">
            <button type="submit" class="remove-btn" title="Remove">&times;</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>

  <div class="cart-summary">
    <div class="summary-row">
      <span>Subtotal</span>
      <span>$<%= subtotal %></span>
    </div>
    <div class="summary-row">
      <span>Shipping</span>
      <span>
        <% if (parseFloat(shipping) === 0) { %>
          <span style="color:#166534">FREE</span>
        <% } else { %>
          $<%= shipping %>
        <% } %>
      </span>
    </div>
    <div class="summary-row total">
      <span>Total</span>
      <span>$<%= total %></span>
    </div>
    <a href="/checkout" class="btn checkout-btn">Proceed to Checkout</a>
    <% if (parseFloat(subtotal) < freeShippingThreshold) { %>
    <p class="free-shipping-note">
      Add $<%= (freeShippingThreshold - parseFloat(subtotal)).toFixed(2) %> more for free shipping
    </p>
    <% } %>
  </div>
  <% } %>
</div>
