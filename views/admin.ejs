<div class="container admin-page">
  <div class="admin-bar">
    <h1>Admin Dashboard</h1>
    <div>
      <button onclick="syncProducts()" class="btn btn-sm">Sync Products</button>
    </div>
  </div>

  <% if (error) { %>
  <div class="alert"><%= error %></div>
  <% } %>

  <table class="admin-table">
    <thead>
      <tr>
        <th>Product</th>
        <th>Collection</th>
        <th>Price</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% if (products && products.length > 0) { %>
        <% products.forEach(p => { %>
        <tr>
          <td>
            <div class="admin-product">
              <img src="<%= p.image || p.images?.[0] || '' %>" alt="<%= p.title %>">
              <div>
                <strong><%= p.title %></strong>
                <div style="font-size:11px;color:#888"><%= p.id %></div>
              </div>
            </div>
          </td>
          <td><span class="badge badge-catalog"><%= p.collection === 'nova-signature' ? 'Nova Signature' : 'The Basics' %></span></td>
          <td>$<%= typeof p.price === 'number' ? p.price.toFixed(2) : parseFloat(p.variants?.[0]?.price || p.price).toFixed(2) %></td>
          <td><span class="badge badge-published">Active</span></td>
        </tr>
        <% }) %>
      <% } else { %>
        <tr><td colspan="4" style="text-align:center;padding:40px;color:#888">No products found.</td></tr>
      <% } %>
    </tbody>
  </table>

  <p style="margin-top:20px;font-size:12px;color:#888">
    Source: Catalog (8 products). Add PRINTIFY_API_KEY to .env to sync with Printify.
  </p>
</div>

<script>
async function syncProducts() {
  const btn = event.target;
  btn.disabled = true;
  btn.textContent = 'Syncing...';
  try {
    const res = await fetch('/admin/sync', { method: 'POST' });
    const data = await res.json();
    if (data.success) {
      btn.textContent = `✓ ${data.count} products (${data.source})`;
      setTimeout(() => location.reload(), 1000);
    } else {
      btn.textContent = '✗ Failed';
    }
  } catch (err) {
    btn.textContent = '✗ Error';
  }
  btn.disabled = false;
}
</script>
