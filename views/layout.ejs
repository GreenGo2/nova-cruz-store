<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title><%= BRAND.name %> — Premium Gym Wear</title>
<meta name="description" content="<%= BRAND.tagline %> Premium gym wear designed for the grind. By Nova Cruz.">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏋️</text></svg>">
<link rel="stylesheet" href="/css/main.css">
</head>
<body>

<nav>
  <a href="/" class="logo"><%= BRAND.name %></a>
  <div class="nav-links">
    <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Home</a>
    <a href="/products" class="<%= currentPath.startsWith('/products') ? 'active' : '' %>">Shop</a>
    <a href="/about" class="<%= currentPath === '/about' ? 'active' : '' %>">About</a>
    <a href="/cart" class="cart-link <%= currentPath === '/cart' ? 'active' : '' %>">
      Cart
      <% if (cartCount > 0) { %><span class="cart-badge"><%= cartCount %></span><% } %>
    </a>
  </div>
</nav>

<main>
<%- body %>
</main>

<footer>
  <div class="footer-grid">
    <div class="footer-col">
      <h4><%= BRAND.name %></h4>
      <p>Premium gym wear designed for the grind. Built by athletes, for athletes. Every piece designed to move with you.</p>
    </div>
    <div class="footer-col">
      <h4>Shop</h4>
      <a href="/products">All Products</a>
      <a href="/products?collection=the-basics">The Basics</a>
      <a href="/products?collection=nova-signature">Nova Signature</a>
      <a href="/cart">Your Cart</a>
    </div>
    <div class="footer-col">
      <h4>Brand</h4>
      <a href="/about">Our Story</a>
      <a href="https://instagram.com/nova.cruz.fit" target="_blank"><%= BRAND.instagram %></a>
      <a href="/admin">Admin</a>
    </div>
    <div class="footer-col">
      <h4>Support</h4>
      <a href="mailto:info@luxuryapartmentnyc.com">Contact</a>
      <a href="#">Shipping & Returns</a>
      <a href="#">Size Guide</a>
    </div>
  </div>
  <div class="footer-bottom">
    &copy; 2025 <%= BRAND.name %>. All rights reserved. Free shipping on orders over $75.
  </div>
</footer>

</body>
</html>
